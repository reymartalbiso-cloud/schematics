# Copy this file to .env and fill in real values. .env is gitignored and never committed.

# Required for real Claude generation. Without it, the app has no way to call the API.
ANTHROPIC_API_KEY=

# Optional - defaults to claude-opus-4-8 if unset.
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional - set to enable the shared-password login gate. Leave unset to disable auth entirely.
# APP_PASSWORD=

# Optional - random secret used to sign session cookies. Auto-generated per-process if unset
# (fine for local use; set explicitly in production so sessions survive a restart).
# FLASK_SECRET_KEY=

# Optional - set to 1 only for local development. Never enable in a real deployment (loosens
# cookie security and can expose the Werkzeug debugger).
# FLASK_DEBUG=0

# Optional - enables Upstash Redis as the memory/designs backend instead of the local JSON file.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
